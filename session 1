--deficient number // find all divisors

class Solution {
  public:
    vector<int> getDivisors(int n) {
        set<int> ans;
        for(int i = 1 ; i*i <= n ; i++)
        if(n%i==0){
            ans.insert(i);
            ans.insert(n/i);
        } 
    
    
       vector<int> res(ans.begin(),ans.end());
       return res;
    }
};
